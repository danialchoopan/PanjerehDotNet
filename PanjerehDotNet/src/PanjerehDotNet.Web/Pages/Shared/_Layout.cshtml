<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنجره دات‌نت</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 font-sans text-gray-900">
    <header class="bg-white border-b sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <a href="/" class="text-red-600 text-2xl font-black">پنجره</a>
                <nav class="hidden md:flex gap-6 text-sm font-medium text-gray-600">
                    <a href="/" class="hover:text-red-600">آگهی‌ها</a>
                    <a href="/Chat" class="hover:text-red-600">چت</a>
                </nav>
            </div>
            <div class="flex items-center gap-4">
                <a href="/Admin" class="text-sm text-gray-500 hover:text-gray-800">پنل مدیریت</a>
                <a href="/PostAd" class="bg-red-600 text-white px-4 py-2 rounded font-bold text-sm hover:bg-red-700 transition">ثبت آگهی</a>
                <div id="auth-section">
                    <a href="/Login" class="text-sm border border-gray-300 px-3 py-2 rounded hover:bg-gray-50">ورود</a>
                </div>
            </div>
        </div>
    </header>

    <main class="min-h-[calc(100vh-120px)]">
        @RenderBody()
    </main>

    <footer class="bg-white border-t py-8 mt-12">
        <div class="max-w-7xl mx-auto px-4 text-center text-gray-500 text-sm">
            <p>© 1403 سامانه نیازمندی‌های آنلاین پنجره دات‌نت - تمامی حقوق محفوظ است</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
