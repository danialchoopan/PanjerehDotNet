<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PanjerehDotNet</title>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
</head>
<body class="light transition-colors duration-300">
    <header class="border-b p-4 flex justify-between items-center sticky top-0 bg-white z-50">
        <div class="flex items-center gap-4">
            <h1 class="text-2xl font-bold text-red-700">پنجره</h1>
            <nav class="hidden md:flex gap-4">
                <a href="/" class="hover:text-red-700">آگهی‌ها</a>
                <a href="/Chat" class="hover:text-red-700">چت</a>
                <a href="/Admin" class="hover:text-red-700">پنل مدیریت</a>
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <button id="themeToggle" class="p-2 border rounded">تغییر تم</button>
            <a href="/Login" class="bg-red-700 text-white px-4 py-2 rounded">ورود</a>
            <a href="/PostAd" class="border border-red-700 text-red-700 px-4 py-2 rounded">ثبت آگهی</a>
        </div>
    </header>
    <main role="main" class="container mx-auto p-4">
        @RenderBody()
    </main>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
