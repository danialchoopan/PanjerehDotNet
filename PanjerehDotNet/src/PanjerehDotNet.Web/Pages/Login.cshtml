@page
@model LoginModel
@{
    ViewData["Title"] = "ورود";
}

<div class="max-w-md mx-auto mt-20 p-8 bg-white rounded-lg shadow-md border">
    <h2 class="text-2xl font-bold text-center mb-6">ورود به پنجره</h2>
    <form method="post">
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">شماره موبایل</label>
            <input type="text" name="PhoneNumber" class="w-full p-3 border rounded-md focus:ring-red-500 focus:border-red-500" placeholder="مثلاً ۰۹۱۲۱۲۳۴۵۶۷" required>
        </div>
        <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-md font-bold hover:bg-red-700 transition">دریافت کد تایید</button>
    </form>
    <p class="mt-6 text-xs text-gray-500 text-center">
        با ورود به پنجره، <a href="#" class="text-red-600">شرایط استفاده از خدمات</a> و <a href="#" class="text-red-600">حریم خصوصی</a> آن را می‌پذیرید.
    </p>
</div>
