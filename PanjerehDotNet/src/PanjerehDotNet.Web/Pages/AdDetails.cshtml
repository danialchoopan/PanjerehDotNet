@page "{id:int}"
@model AdDetailsModel
@{
    ViewData["Title"] = Model.Ad.Title;
}

<div class="max-w-7xl mx-auto px-4 py-8">
    <nav class="flex text-sm text-gray-500 mb-6 gap-2">
        <a href="/" class="hover:text-red-600">صفحه اصلی</a>
        <span>/</span>
        <span class="text-gray-900">@Model.Ad.Title</span>
    </nav>

    <div class="flex flex-col lg:flex-row gap-12">
        <!-- Main Content -->
        <div class="flex-1">
            <div class="aspect-w-16 aspect-h-9 bg-gray-100 rounded-2xl overflow-hidden mb-8 shadow-inner flex items-center justify-center">
                <div class="text-gray-300 flex flex-col items-center gap-4">
                    <svg width="128" height="128" class="w-32 h-32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <span class="font-bold text-xl">تصویر آگهی</span>
                </div>
            </div>

            <div class="prose max-w-none">
                <h2 class="text-xl font-black text-gray-900 mb-4 border-r-4 border-red-600 pr-4">توضیحات</h2>
                <p class="text-gray-700 leading-loose whitespace-pre-wrap">@Model.Ad.Description</p>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="lg:w-96">
            <div class="bg-white border border-gray-200 rounded-2xl p-6 sticky top-24 shadow-sm">
                <h1 class="text-2xl font-black text-gray-900 mb-2 leading-snug">@Model.Ad.Title</h1>
                <p class="text-gray-500 text-sm mb-6 pb-6 border-b">@Model.Ad.District | لحظاتی پیش</p>

                <div class="space-y-6">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600">قیمت</span>
                        <span class="text-xl font-black text-rose-600">@Model.Ad.Price.ToString("N0") تومان</span>
                    </div>

                    <div class="grid grid-cols-1 gap-3">
                        <button class="w-full bg-red-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-red-700 transition shadow-lg shadow-red-100 flex items-center justify-center gap-2">
                            <svg width="20" height="20" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            اطلاعات تماس
                        </button>
                        <a href="/Chat?adId=@Model.Ad.Id&otherUserId=@Model.Ad.UserId" class="w-full border-2 border-gray-200 text-gray-700 py-4 rounded-xl font-bold text-lg hover:bg-gray-50 transition flex items-center justify-center gap-2">
                            <svg width="20" height="20" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.827-1.233L3 20l1.341-5.022A8.859 8.859 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                            چت و گفتگو
                        </a>
                    </div>
                </div>

                <div class="mt-8 pt-8 border-t space-y-4">
                    <div class="flex items-center gap-3 text-sm text-gray-500">
                        <svg width="16" height="16" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        <span>خرید امن از طریق درگاه پرداخت</span>
                    </div>
                    <div class="flex items-center gap-3 text-sm text-gray-500">
                        <svg width="16" height="16" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <span>هشدار پلیس: قبل از معامله حضوری مبلغی واریز نکنید</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
