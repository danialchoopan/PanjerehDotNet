@page
@model ChatModel
@{
    ViewData["Title"] = "گفتگو";
}

<div class="max-w-6xl mx-auto h-[calc(100vh-160px)] min-h-[600px] flex flex-row-reverse border rounded-2xl overflow-hidden bg-white shadow-xl my-4">
    <!-- Conversations List -->
    <aside class="w-1/3 border-r flex flex-col bg-slate-50">
        <div class="p-6 border-b bg-white">
            <h1 class="font-black text-xl text-slate-800">چت و گفتگو</h1>
        </div>
        <div class="flex-1 overflow-y-auto">
            @if (!Model.Conversations.Any())
            {
                <div class="p-8 text-center text-slate-400">
                    <p class="text-sm">هنوز گفتگویی ندارید</p>
                </div>
            }
            @foreach (var convo in Model.Conversations)
            {
                <a href="/Chat?adId=@convo.AdId&otherUserId=@(convo.SenderId == Model.CurrentUserId ? convo.ReceiverId : convo.SenderId)"
                   class="block p-4 border-b hover:bg-white transition-all @(convo.AdId == Model.AdId && (convo.SenderId == Model.OtherUserId || convo.ReceiverId == Model.OtherUserId) ? "bg-white border-l-4 border-l-red-600 shadow-inner" : "")">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-red-50 text-red-600 rounded-full flex items-center justify-center font-bold text-lg shrink-0 border border-red-100">
                            @(convo.SenderName?.Substring(0, 1) ?? "U")
                        </div>
                        <div class="flex-1 overflow-hidden">
                            <div class="flex justify-between items-baseline mb-0.5">
                                <span class="font-bold text-sm text-slate-900">@convo.SenderName</span>
                                <span class="text-[10px] text-slate-400">امروز</span>
                            </div>
                            <div class="text-[11px] text-red-600 font-medium mb-1">آگهی: @convo.AdTitle</div>
                            <div class="text-xs text-slate-500 truncate">@convo.Content</div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </aside>

    <!-- Chat Area -->
    <div class="flex-1 flex flex-col bg-white">
        @if (Model.OtherUserId > 0)
        {
            <!-- Chat Header -->
            <div class="p-4 border-b flex items-center justify-between bg-white z-10 shadow-sm">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center font-bold text-slate-600 border border-slate-200">
                        @((Model.OtherUser?.FullName ?? Model.OtherUser?.PhoneNumber ?? "U").Substring(0, 1))
                    </div>
                    <div>
                        <h2 class="font-bold text-slate-900">@(Model.OtherUser?.FullName ?? Model.OtherUser?.PhoneNumber)</h2>
                        <div class="flex items-center gap-1.5">
                            <span class="w-2 h-2 rounded-full bg-green-500"></span>
                            <p id="connection-status" class="text-[10px] text-green-600 font-medium">آنلاین</p>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/AdDetails/@Model.AdId" class="text-red-600 text-xs font-bold px-3 py-1.5 bg-red-50 rounded-lg hover:bg-red-100 transition">مشاهده آگهی</a>
                </div>
            </div>

            <!-- Messages Area -->
            <div id="messages-container" class="flex-1 p-6 overflow-y-auto space-y-6 bg-[#f0f2f5] shadow-inner">
                @foreach (var msg in Model.Messages)
                {
                    var isMine = msg.SenderId == Model.CurrentUserId;
                    <div class="flex @(isMine ? "justify-end" : "justify-start")">
                        <div class="max-w-[75%] @(isMine ? "bg-red-600 text-white rounded-2xl rounded-br-none shadow-md shadow-red-100" : "bg-white text-slate-800 rounded-2xl rounded-bl-none shadow-sm border border-slate-100")">
                            <div class="px-4 py-2.5">
                                <p class="text-sm leading-relaxed">@msg.Content</p>
                            </div>
                            <div class="px-4 pb-1.5 flex @(isMine ? "justify-start" : "justify-end")">
                                <span class="text-[9px] opacity-60 font-medium">@msg.SentAt.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="p-4 bg-white border-t">
                <form id="chat-form" class="flex gap-3 items-center">
                    <div class="flex-1 relative">
                        <input id="message-input" type="text" placeholder="پیام خود را بنویسید..."
                               class="w-full pl-4 pr-4 py-3 bg-slate-100 border-none rounded-xl focus:ring-2 focus:ring-red-500 focus:bg-white transition-all text-sm" autocomplete="off" />
                    </div>
                    <button type="submit" class="bg-red-600 text-white p-3 rounded-xl hover:bg-red-700 transition shadow-lg shadow-red-100 shrink-0">
                        <svg width="20" height="20" class="w-5 h-5 transform rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="flex-1 flex items-center justify-center text-slate-300 flex-col gap-6 bg-slate-50">
                <div class="w-24 h-24 bg-white rounded-full flex items-center justify-center shadow-sm border border-slate-100">
                    <svg width="48" height="48" class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.827-1.233L3 20l1.341-5.022A8.859 8.859 0 013 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                </div>
                <div class="text-center">
                    <p class="font-bold text-slate-500">گفتگویی را انتخاب کنید</p>
                    <p class="text-xs mt-2">برای شروع گفتگو، یکی از پیام‌های سمت راست را انتخاب کنید</p>
                </div>
            </div>
        }
    </div>
</div>

@if (Model.OtherUserId > 0)
{
    <script src="~/lib/signalr/dist/browser/signalr.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        const currentUserId = @Model.CurrentUserId;
        const otherUserId = @Model.OtherUserId;
        const adId = @Model.AdId;

        connection.on("ReceiveMessage", function (senderId, receivedAdId, message) {
            if (receivedAdId == adId && (senderId == otherUserId || senderId == currentUserId)) {
                appendMessage(senderId, message);
            }
        });

        connection.start().then(function () {
            const status = document.getElementById("connection-status");
            if(status) {
                status.innerText = "آنلاین";
                status.classList.remove("text-slate-400");
                status.classList.add("text-green-600");
            }
        }).catch(function (err) {
            return console.error(err.toString());
        });

        document.getElementById("chat-form").addEventListener("submit", function (event) {
            const content = document.getElementById("message-input").value;
            if (content && content.trim() !== "") {
                connection.invoke("SendMessage", otherUserId, adId, content).catch(function (err) {
                    return console.error(err.toString());
                });
                document.getElementById("message-input").value = "";
            }
            event.preventDefault();
        });

        function appendMessage(senderId, content) {
            const container = document.getElementById("messages-container");
            const isMine = senderId == currentUserId;
            const div = document.createElement("div");
            div.className = "flex " + (isMine ? "justify-end" : "justify-start");

            const now = new Date();
            const time = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');

            div.innerHTML = `
                <div class="max-w-[75%] ${isMine ? 'bg-red-600 text-white rounded-2xl rounded-br-none shadow-md shadow-red-100' : 'bg-white text-slate-800 rounded-2xl rounded-bl-none shadow-sm border border-slate-100'}">
                    <div class="px-4 py-2.5">
                        <p class="text-sm leading-relaxed">${content}</p>
                    </div>
                    <div class="px-4 pb-1.5 flex ${isMine ? 'justify-start' : 'justify-end'}">
                        <span class="text-[9px] opacity-60 font-medium">${time}</span>
                    </div>
                </div>
            `;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        const container = document.getElementById("messages-container");
        if(container) container.scrollTop = container.scrollHeight;
    </script>
}
