@page
@model AdminModel
<div style="padding: 30px; background: #f4f6f9; min-height: 100vh;">
    <h1 style="font-weight: 900; margin-bottom: 30px; color: #1a202c;">پنل مدیریت هوشمند پنجره</h1>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
        <div style="background: #fff; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border-right: 5px solid #4299e1;">
            <div style="color: #a0aec0; font-size: 14px; font-weight: bold;">کل آگهی‌ها</div>
            <div style="font-size: 32px; font-weight: 900; margin-top: 10px;">@Model.Stats.TotalAds</div>
        </div>
        <div style="background: #fff; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border-right: 5px solid #48bb78;">
            <div style="color: #a0aec0; font-size: 14px; font-weight: bold;">تایید شده</div>
            <div style="font-size: 32px; font-weight: 900; margin-top: 10px; color: #48bb78;">@Model.Stats.ApprovedAds</div>
        </div>
        <div style="background: #fff; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border-right: 5px solid #f56565;">
            <div style="color: #a0aec0; font-size: 14px; font-weight: bold;">در انتظار</div>
            <div style="font-size: 32px; font-weight: 900; margin-top: 10px; color: #f56565;">@Model.Stats.PendingAds</div>
        </div>
        <div style="background: #fff; padding: 25px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); border-right: 5px solid #ed8936;">
            <div style="color: #a0aec0; font-size: 14px; font-weight: bold;">گزارش‌ها</div>
            <div style="font-size: 32px; font-weight: 900; margin-top: 10px; color: #ed8936;">@Model.Stats.ReportCount</div>
        </div>
    </div>
    <div style="background: #fff; border-radius: 15px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.02);">
        <div style="padding: 20px; background: #edf2f7; font-weight: bold; border-bottom: 1px solid #e2e8f0;">لیست گزارش‌های تخلف اخیر</div>
        <table style="width: 100%; border-collapse: collapse; text-align: right;">
            <thead>
                <tr style="color: #718096; font-size: 12px; background: #f8fafc;">
                    <th style="padding: 15px 25px; border-bottom: 2px solid #e2e8f0;">عنوان آگهی</th>
                    <th style="padding: 15px 25px; border-bottom: 2px solid #e2e8f0;">علت گزارش</th>
                    <th style="padding: 15px 25px; border-bottom: 2px solid #e2e8f0;">توضیحات مدیریت</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var r in Model.Reports) {
                    <tr style="border-bottom: 1px solid #edf2f7;">
                        <td style="padding: 15px 25px; font-weight: bold; color: #2d3748;">@r.Advertisement?.Title</td>
                        <td style="padding: 15px 25px; color: #e53e3e; font-weight: bold;">@r.Reason</td>
                        <td style="padding: 15px 25px; color: #4a5568;">@r.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
