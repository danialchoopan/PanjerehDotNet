@page
@model AdminModel
@{
    ViewData["Title"] = "پنل مدیریت";
}

<div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-black text-gray-900 mb-8">پنل مدیریت هوشمند پنجره</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-white shadow-sm rounded-xl p-6 border border-slate-100 flex items-center justify-between">
            <div>
                <div class="text-slate-500 text-sm font-bold mb-1">کل آگهی‌ها</div>
                <div class="text-3xl font-black text-slate-900">@Model.Stats.TotalAds</div>
            </div>
            <div class="bg-blue-50 p-3 rounded-lg text-blue-600">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            </div>
        </div>

        <div class="bg-white shadow-sm rounded-xl p-6 border border-slate-100 flex items-center justify-between">
            <div>
                <div class="text-slate-500 text-sm font-bold mb-1">تایید شده</div>
                <div class="text-3xl font-black text-emerald-600">@Model.Stats.ApprovedAds</div>
            </div>
            <div class="bg-emerald-50 p-3 rounded-lg text-emerald-600">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
        </div>

        <div class="bg-white shadow-sm rounded-xl p-6 border border-slate-100 flex items-center justify-between">
            <div>
                <div class="text-slate-500 text-sm font-bold mb-1">در انتظار</div>
                <div class="text-3xl font-black text-rose-600">@Model.Stats.PendingAds</div>
            </div>
            <div class="bg-rose-50 p-3 rounded-lg text-rose-600">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
        </div>

        <div class="bg-white shadow-sm rounded-xl p-6 border border-slate-100 flex items-center justify-between">
            <div>
                <div class="text-slate-500 text-sm font-bold mb-1">گزارش‌ها</div>
                <div class="text-3xl font-black text-amber-600">@Model.Stats.ReportCount</div>
            </div>
            <div class="bg-amber-50 p-3 rounded-lg text-amber-600">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="px-6 py-4 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
            <h2 class="font-bold text-slate-800">لیست گزارش‌های تخلف اخیر</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-right border-collapse">
                <thead>
                    <tr class="text-slate-400 text-xs uppercase tracking-wider">
                        <th class="px-6 py-4 font-medium">عنوان آگهی</th>
                        <th class="px-6 py-4 font-medium">علت گزارش</th>
                        <th class="px-6 py-4 font-medium">توضیحات</th>
                        <th class="px-6 py-4 font-medium">عملیات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach(var r in Model.Reports) {
                        <tr class="hover:bg-slate-50 transition even:bg-slate-50/50">
                            <td class="px-6 py-4 font-bold text-slate-700">@r.Advertisement?.Title</td>
                            <td class="px-6 py-4">
                                <span class="text-rose-600 bg-rose-50 font-medium rounded-full text-xs px-2.5 py-1">@r.Reason</span>
                            </td>
                            <td class="px-6 py-4 text-slate-500 text-sm">@r.Description</td>
                            <td class="px-6 py-4">
                                <div class="flex gap-2">
                                    <form method="post" asp-page-handler="Approve" asp-route-id="@r.AdvertisementId">
                                        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs px-3 py-1.5 rounded-lg transition">تایید</button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" asp-route-id="@r.AdvertisementId">
                                        <button type="submit" class="bg-rose-600 hover:bg-rose-700 text-white text-xs px-3 py-1.5 rounded-lg transition">رد</button>
                                    </form>
                                    <form method="post" asp-page-handler="BanUser" asp-route-id="@r.Advertisement?.UserId">
                                        <button type="submit" class="bg-slate-800 hover:bg-black text-white text-xs px-3 py-1.5 rounded-lg transition">مسدود سازی</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
